{
  "name": "test-runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c green,blue \"node --import tsx --watch server/index.ts\" \"wait-on -t 30000 http://127.0.0.1:8767/api/config && vite\"",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit --project tsconfig.app.json && tsc --noEmit --project tsconfig.server.json"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "lucide-react": "^0.544.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.0",
    "typescript": "~5.8.3",
    "vite": "^7.1.7",
    "wait-on": "^8.0.3"
  }
}
